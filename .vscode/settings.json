{
    // "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",


    // --- STOPPED the built-in markdown preview editor for .md files ---
    // "workbench.editorAssociations": {   
    //     "*.md": "vscode.markdown.preview.editor"
    // },


    "[javascriptreact]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },

    // Python Environments config
    // Set to pipenv so VS Code uses the project's Pipfile/Pipfile.lock
    // and automatically selects the correct interpreter/environment.
    "python-envs.defaultEnvManager": "ms-python.python:pipenv",
    "python-envs.pythonProjects": [],


    // Set a default file icon theme for this workspace (change the id if different theme is preferred)
    "workbench.iconTheme": "vscode-icons"
}
